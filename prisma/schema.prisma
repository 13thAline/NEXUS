// prisma/schema.prisma — NEXUS Database Schema
// PostgreSQL on Cloud SQL (replaces SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Incident {
  id             String        @id @default(cuid())
  source         String        // e.g. "FIRE_PANEL_ZONE_3E", "GUEST_PANIC_BUTTON_512"
  rawPayload     String        @db.Text
  timestamp      DateTime      @default(now())
  status         String        @default("PENDING") // PENDING | TRIAGING | BUILDING_GRAPH | COMPUTING_PRIORITIES | GENERATING_STRATEGY | ACTIVE | CONTAINED | RESOLVED | PIPELINE_FAILED
  llmReasoning   String?       @db.Text
  coverageGaps   String?       // JSON string array
  warnings       String?       // JSON string array
  generatedBy    String?       // "gemini-pro" | "gemma-fallback"
  pipelineMs     Int?
  resolvedAt     DateTime?

  // Legacy fields kept for backward compat with existing frontend
  type           String?       // Populated by Stage 1 triage
  severity       String?       // Populated by Stage 1 triage
  zone           String?       // Populated by Stage 1 triage
  floor          Int?          // Populated by Stage 1 triage

  // Reports (populated after containment)
  analysisReport String?       @db.Text
  metrics        String?

  tasks          Task[]
  logs           IncidentLog[]
}

model Task {
  id             String    @id @default(cuid())
  incidentId     String
  incident       Incident  @relation(fields: [incidentId], references: [id])
  staffId        String
  staffName      String
  staffRole      String
  description    String    @db.Text
  priority       Int
  floor          Int
  zone           String
  status         String    @default("PENDING") // PENDING | ACKNOWLEDGED | COMPLETE
  llmReasoning   String?   @db.Text
  assignedAt     DateTime  @default(now())
  acknowledgedAt DateTime?
  completedAt    DateTime?
}

model IncidentLog {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])
  event      String
  data       String   @db.Text @default("")
  timestamp  DateTime @default(now())
}