# ═══════════════════════════════════════════════════════
# NEXUS — Environment Variables
# Copy this file to .env.local and fill in all values
# ═══════════════════════════════════════════════════════

# ─── Database (Cloud SQL PostgreSQL) ──────────────────
# Local dev with Docker:
#   docker run -d --name nexus-db -e POSTGRES_USER=nexus -e POSTGRES_PASSWORD=nexus -e POSTGRES_DB=nexus -p 5432:5432 postgres:16
#   DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus"
#
# Cloud SQL (production):
#   DATABASE_URL="postgresql://USER:PASSWORD@localhost/nexus?host=/cloudsql/PROJECT:REGION:INSTANCE"
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus"

# ─── Google Gemini AI ─────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Google Cloud Platform ────────────────────────────
# Project ID from GCP Console
GCP_PROJECT_ID=
# Region for Vertex AI endpoints
GCP_LOCATION=us-central1

# ─── Ollama (Local Fallback — gemma:7b) ───────────────
# Only used when Gemini Pro times out (55s)
# Make sure Ollama is running: ollama serve
# And model is pulled: ollama pull gemma:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=gemma:7b

# ─── Firebase (Client-side — exposed to browser) ──────
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (Server-side — NEVER expose) ──────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE JSON file content as a single-line string
FIREBASE_SERVICE_ACCOUNT_KEY=
